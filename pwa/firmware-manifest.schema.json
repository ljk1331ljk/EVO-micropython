{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ljk1331ljk/EVO-micropython/pwa/firmware-manifest.schema.json",
  "title": "EVO MicroPython firmware release manifest",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "version",
    "channel",
    "repository",
    "commit",
    "release_tag",
    "prerelease",
    "generated_at",
    "devices"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "channel": {
      "enum": [
        "stable",
        "beta"
      ]
    },
    "repository": {
      "type": "string"
    },
    "commit": {
      "type": "string"
    },
    "release_tag": {
      "type": "string"
    },
    "prerelease": {
      "type": "boolean"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "base_url": {
      "type": "string",
      "format": "uri"
    },
    "devices": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "board",
          "variant",
          "product",
          "port",
          "chip",
          "assets",
          "flash_sequence"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "board": {
            "type": "string"
          },
          "variant": {
            "type": "string"
          },
          "product": {
            "type": "string"
          },
          "port": {
            "type": "string"
          },
          "chip": {
            "type": "string"
          },
          "assets": {
            "type": "object",
            "required": [
              "bootloader",
              "partition_table",
              "application"
            ],
            "additionalProperties": {
              "$ref": "#/$defs/asset"
            }
          },
          "flash_sequence": {
            "type": "array",
            "minItems": 3,
            "items": {
              "$ref": "#/$defs/flash_entry"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "asset": {
      "type": "object",
      "required": [
        "file",
        "sha256",
        "size"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "offset": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "size": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "flash_entry": {
      "type": "object",
      "required": [
        "path",
        "address",
        "description"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "address": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]+$"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
